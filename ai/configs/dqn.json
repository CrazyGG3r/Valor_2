{
  "env": {
    "port": 11008,
    "max_episode_steps": 2000
  },
  "agent": {
    "hidden_sizes": [128, 128],
    "lr": 0.0003,
    "gamma": 0.99,
    "buffer_size": 100000,
    "batch_size": 64,
    "warmup_steps": 1000,
    "target_update_every": 1000,
    "epsilon_start": 1.0,
    "epsilon_end": 0.05,
    "epsilon_decay_steps": 50000,
    "device": "auto"
  },
  "training": {
    "checkpoint_every": 25
  }
}
