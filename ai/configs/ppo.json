{
  "env": {
    "port": 11008,
    "max_episode_steps": 2000
  },
  "agent": {
    "hidden_sizes": [128, 128],
    "lr": 0.0003,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_ratio": 0.2,
    "rollout_steps": 2048,
    "minibatch_size": 64,
    "update_epochs": 4,
    "entropy_coef": 0.01,
    "value_coef": 0.5,
    "device": "auto"
  },
  "training": {
    "checkpoint_every": 25
  }
}
